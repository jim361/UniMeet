{
  "expo": {
    "name": "UniMeet",
    "slug": "unimeet",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "unimeet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A2E5A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
